DESCRIPTION
"This is a modified copy of the original model definition file."
"The original observables and errors have been removed."
"New, realistically drawn observables are defined in the data definition files."

"Original project:	Swameye_PNAS2003"
"RS project name:	Swameye_RS45"
"Random seed:		0001645000."

"Original description:"

"JAK-STAT Model: This model is the D2D-version of the Swameye model published in PNAS in 2003. Compared to the published model, the delay is implemented via the chain-trick with 5 compartements. Error parameters for the observations are introduced (which are by default, i.e. in case of ar.config.fiterrors=0 overwritten by the exp. errors and therefore not used."
"Additionally, the spline has been changed from spline_pos5 to spline_pos10. The 5 additional knots are fixed and used to prohibit divergence of the spline for longer times."


PREDICTOR
t               T   min         time	0	80


COMPARTMENTS
cyt             V   "pl"      "vol."        1.4
nuc             V   "pl"      "vol."        0.45


STATES
STAT            C   "nM"      "conc."    cyt
pSTAT           C   "nM"      "conc."    cyt
pSTAT_pSTAT     C   "nM"      "conc."    cyt
npSTAT_npSTAT   C   "nM"      "conc."    nuc
nSTAT1          C   "nM"      "conc."    nuc
nSTAT2          C   "nM"      "conc."    nuc
nSTAT3          C   "nM"      "conc."    nuc
nSTAT4          C   "nM"      "conc."    nuc
nSTAT5          C   "nM"      "conc."    nuc


INPUTS
// pEpoR           C   "au"      "conc."   "spline_pos5(t, 0.0, sp1, 5.0, sp2, 10.0, sp3, 20.0, sp4, 60.0, sp5, 0, 0.0)"
pEpoR           C   "au"      "conc."   "spline_pos10(t, 0.0, sp1, 5.0, sp2, 10.0, sp3, 20.0, sp4, 60.0, sp5, t6, spEq, t7, spEq, t8, spEq, t9, spEq, t10, spEq, 0, 0.0)"


REACTIONS
STAT             ->  pSTAT            CUSTOM "p1 * pEpoR * STAT"
pSTAT + pSTAT    ->  pSTAT_pSTAT      CUSTOM "p2 * pSTAT^2"
pSTAT_pSTAT      ->  npSTAT_npSTAT    CUSTOM "p3 * pSTAT_pSTAT"

// dissociation, delay and export 
npSTAT_npSTAT    ->  nSTAT1 + nSTAT1  CUSTOM "p4 * npSTAT_npSTAT" // test
nSTAT1           ->  nSTAT2           CUSTOM "p4 * nSTAT1"
nSTAT2           ->  nSTAT3           CUSTOM "p4 * nSTAT2"
nSTAT3           ->  nSTAT4           CUSTOM "p4 * nSTAT3"
nSTAT4           ->  nSTAT5           CUSTOM "p4 * nSTAT4"
nSTAT5           ->  STAT             CUSTOM "p4 * nSTAT5"


DERIVED
tSTAT           C   "nM"  "conc."    "STAT + pSTAT + 2*pSTAT_pSTAT"
tpSTAT          C   "nM"  "conc."    "pSTAT + 2*pSTAT_pSTAT"


OBSERVABLES


ERRORS


CONDITIONS
init_nSTAT1	"(0)"
init_nSTAT2	"(0)"
init_nSTAT3	"(0)"
init_nSTAT4	"(0)"
init_nSTAT5	"(0)"
init_npSTAT_npSTAT	"(0)"
init_pSTAT	"(0)"
init_pSTAT_pSTAT	"(0)"
p2	"(p2 / init_STAT)"
spEq	"(1e-5)"
t10	"(160)"
t6	"(80)"
t7	"(100)"
t8	"(120)"
t9	"(140)"


PARAMETERS
init_STAT	0	2	1	-5	3
p1	0.543	1	1	-5	3
p2	2.7	1	1	-5	3
p3	-0.655	1	1	-5	3
p4	-0.136	1	1	-5	3
sp1	-2.66	1	1	-5	3
sp2	-0.38	1	1	-5	3
sp3	-0.101	1	1	-5	3
sp4	-0.169	1	1	-5	3
sp5	-4.37	1	1	-5	3
