Kz	-0.384	1	1	-4	3
Vd	2.22	1	1	-1	6
Vm2	0.845	1	1	-3	4
Vm3	1.22	1	1	-2	5
Vp	0.377	1	1	-3	4
beta_par	0.173	1	1	-3	4
epsilon_par	-0.745	1	1	-4	3
init_A_state	1	1	0	0	1000
init_Y_state	1.12	1	0	0	1120
init_Z_state	0.143	1	0	0	143
n_par	0.816	1	1	-3	4
v0	0.512	1	1	-3	4
