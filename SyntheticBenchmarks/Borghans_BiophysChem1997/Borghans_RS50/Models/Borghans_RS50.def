Kz	-0.775	1	1	-4	3
Vd	1.88	1	1	-2	5
Vm2	1.11	1	1	-2	5
Vm3	1.52	1	1	-2	5
Vp	0.536	1	1	-3	4
beta_par	0.083	1	1	-3	4
epsilon_par	-1.03	1	1	-5	2
init_A_state	0.796	1	0	0	796
init_Y_state	0.508	1	0	0	508
init_Z_state	0.0696	1	0	0	70
