DESCRIPTION
"This is a modified copy of the original model definition file."
"The original observables and errors have been removed."
"New, realistically drawn observables are defined in the data definition files."

"Original project:	Borghans_BiophysChem1997"
"RS project name:	Borghans_RS01"
"Random seed:		0000401000."

"Original description:"

"Borghans1997 - Calcium Oscillation - Model 3"


PREDICTOR
t	 T	 "n/a"	 time	 0	 10


COMPARTMENTS
extracellular	 V	 "n/a"	 vol.	 1
cytosol	 V	 "n/a"	 vol.	 1
intravesicular	 V	 "n/a"	 vol.	 1


STATES
Z_state	 C	 "n/a"	 conc.	 cytosol	 1	 "Ca^{2+} in cytosol"
Y_state	 C	 "n/a"	 conc.	 intravesicular	 1	 "Ca^{2+} in Ca^{2+}-sensitive pool"
A_state	 C	 "n/a"	 conc.	 cytosol	 1	 "IP_3 concentration"


INPUTS


REACTIONS
-> Z_state 	 CUSTOM "v0+v1*beta_par"
Z_state 	-> Y_state 	 CUSTOM "Vm2*Z_state^2/(K2^2+Z_state^2)"
Y_state 	-> Z_state 	 CUSTOM "Vm3*A_state^4*Y_state^2*Z_state^4/((Ka^4+A_state^4)*(Ky^2+Y_state^2)*(Kz^4+Z_state^4))"
Y_state 	-> Z_state 	 CUSTOM "Kf*Y_state"
Z_state 	->  	 CUSTOM "K_par*Z_state"
 	-> A_state 	 CUSTOM "beta_par*Vp"
A_state 	->  	 CUSTOM "Vd*A_state^2*Z_state^n_par/((Kp^2+A_state^2)*(Kd^n_par+Z_state^n_par))"
A_state 	->  	 CUSTOM "epsilon_par*A_state"


DERIVED


OBSERVABLES


ERRORS


CONDITIONS


PARAMETERS
K2	-1.25	1	1	-3	5
K_par	0.934	1	1	-3	5
Ka	-0.729	1	1	-3	5
Kd	-0.395	1	1	-3	5
Kf	0.308	1	1	-3	5
Kp	0.0308	1	1	-3	5
Ky	-0.673	1	1	-3	5
Kz	-0.663	1	1	-3	5
Vd	2.2	1	1	-3	5
Vm2	0.927	1	1	-3	5
Vm3	1.38	1	1	-3	5
Vp	0.246	1	1	-3	5
beta_par	0.21	1	1	-3	5
epsilon_par	-0.842	1	1	-3	5
init_A_state	1.01	1	0	0	1.100000e+00
init_Y_state	1.22	1	0	0	1.300000e+00
init_Z_state	0.0774	1	0	0	1
n_par	0.711	1	1	-3	5
v0	0.464	1	1	-3	5
v1	-0.12	1	1	-3	5
