DESCRIPTION
"Experimenter: Julie Bachmann"
"Cells: CFU-E"
"Ligand: Epo 5 units/ml (1.25e-7 units/cell)"

PREDICTOR
t               T   min     time	0	250

INPUTS

OBSERVABLES
pJAK2_au            C   au  conc.   1   1   "offset_pJAK2_long + scale_pJAK2_long / init_EpoRJAK2 * pJAK2"
pEpoR_au            C   au  conc.   1   1   "offset_pEpoR_long + scale_pEpoR_long / init_EpoRJAK2 * pEpoR"
CIS_au              C   au  conc.   1   1   "offset_CIS_long + scale_CIS_long / CISeqm_model / CISHRNAeqm_model / init_STAT5 * CIS"
// SOCS3_au            C   au  conc.   1   1   "offset_SOCS3_long + scale_SOCS3_long / SOCS3eqm_model / SOCS3RNAeqm_model / init_STAT5 * SOCS3"
SOCS3_au            C   au  conc.   1   1   "offset_SOCS3_long + scale_SOCS3_long / SOCS3eqm_model / SOCS3RNAeqm_model / init_STAT5^SOCS3prom * SOCS3"
tSTAT5_au           C   au  conc.   1   1   "scale_tSTAT5_long / init_STAT5 * tSTAT5"
pSTAT5_au           C   au  conc.   1   1   "offset_pSTAT5_long + scale_pSTAT5_long / init_STAT5 * pSTAT5"

ERRORS
pJAK2_au		"sd_JAK2EpoR_au"
pEpoR_au		"sd_JAK2EpoR_au"
CIS_au			"sd_CIS_au"
SOCS3_au		"sd_SOCS3_au"
tSTAT5_au		"sd_STAT5_au"
pSTAT5_au		"sd_STAT5_au"

CONDITIONS
// CFUE specific conditions
step_time           "60"

vol_cyt             "0.4"
vol_nuc             "0.275"

init_CISHRNA        "0.275/0.4*CISHRNAbasal*CISHRNAeqm/CISHRNAturn"
init_CIS            "0.275/0.4*CISeqm/CISHRNAeqm*CISHRNAbasal*CISHRNAeqm/CISHRNAturn"

init_SOCS3nRNA1     "SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAdelay"
init_SOCS3nRNA2     "SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAdelay"
init_SOCS3nRNA3     "SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAdelay"
init_SOCS3nRNA4     "SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAdelay"
init_SOCS3nRNA5     "SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAdelay"
init_SOCS3RNA       "0.275/0.4*SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAturn"
init_SOCS3          "0.275/0.4*SOCS3eqm/SOCS3RNAeqm*SOCS3RNAbasal*SOCS3RNAeqm/SOCS3RNAturn"

// experimental conditions
epo_level			"1.25e-7"
ActD				"0"
SOCS3oe             "0"
