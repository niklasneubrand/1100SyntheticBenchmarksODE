# Ignore all content in these folders
/IMBI_Cluster
/Local_Results
/Benchmark_Models
/tests
/debug
/archive

/RS_IMBI
/RS_local

## Ignore parts of the d2d project folders
pthreadGC2.dll
pthreadVC2.dll

# ignore parts of the Base Models
/BaseModels/**/**/RSTemplate
/BaseModels/**/**/RealisticSimulation

# ignore some base model collections
/BaseModels/nonSBML
/BaseModels/fast_nonSBML

# compiled files with "arCompileAllSetups"
**/Results/*normal
**/CheckSums/
**/Compiled/
*.mexa64
*.mexw64

# Ignore Results directories under any RealisticSimulation
# except those that end with __Final
**/RealisticSimulation/**/Results/
!**/RealisticSimulation/**/Results/*__Final/
**/RealisticSimulation/**/arSimuCalcFun*


## ignore certain other files
project_lib/RealisticSimulation/arDrawObservablesNew.m
/analysisScripts/CRC-Symp_Poster
/presentations/CRC-Symp_Poster


## Ignore files generated by compiling the SyntheticBenchmarks

# Ignore everything inside SyntheticBenchmarks recursively
SyntheticBenchmarks/**

# But do not ignore the SyntheticBenchmarks folder itself and its immediate subdirectories:
!SyntheticBenchmarks/
!SyntheticBenchmarks/*/
!SyntheticBenchmarks/*/*/

# Un-ignore the Setup.m file in each simulation folder
!SyntheticBenchmarks/*/*/Setup.m

# Un-ignore the Data folder and its contents in each simulation folder
!SyntheticBenchmarks/*/*/Data/
!SyntheticBenchmarks/*/*/Data/**

# Un-ignore the Models folder and its contents in each simulation folder
!SyntheticBenchmarks/*/*/Models/
!SyntheticBenchmarks/*/*/Models/**

